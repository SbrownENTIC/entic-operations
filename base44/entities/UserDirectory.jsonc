{
  "name": "UserDirectory",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "User or extension name"
    },
    "extensions": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Array of phone extensions assigned to this user"
    },
    "location": {
      "type": "string",
      "description": "Office location"
    },
    "benchmark_group": {
      "type": "string",
      "enum": [
        "Front Desk",
        "NP Coordinator",
        "Other"
      ],
      "description": "Benchmark category for reporting"
    },
    "daily_goal": {
      "type": "number",
      "description": "Daily call goal"
    },
    "include_in_benchmark": {
      "type": "boolean",
      "default": false,
      "description": "Whether to include in benchmark calculations"
    },
    "active": {
      "type": "boolean",
      "default": true,
      "description": "Whether the user is active"
    },
    "role": {
      "type": "string",
      "description": "Job role or title"
    },
    "expected_answer_rate": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Expected answer rate (0-1)"
    }
  },
  "required": [
    "name"
  ],
  "rls": {
    "create": {
      "user_condition": {
        "role": "admin"
      }
    },
    "read": {
      "user_condition": {
        "role": "admin"
      }
    },
    "update": {
      "user_condition": {
        "role": "admin"
      }
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}